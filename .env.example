TELEGRAM_BOT_TOKEN=your_telegram_bot_token

OLLAMA_BASE_URL=http://ollama.railway.internal:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_NUM_CTX=768
OLLAMA_NUM_PREDICT=400
OLLAMA_NUM_THREAD=1
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9

DATABASE_PATH=/data/ai_sales_agent.db
PUBLIC_TELEGRAM_BOT_LINK=
LEAD_AUTO_REPLY_ENABLED=true
OWNER_TELEGRAM_ID=
WHATSAPP_CONTACT_LINK=
WHATSAPP_PHONE=

THREADS_ACCESS_TOKEN=your_threads_access_token
THREADS_USER_ID=your_threads_user_id
THREADS_API_BASE_URL=https://graph.threads.net

THREADS_AUTO_PUBLISH=true
THREADS_AUTO_POSTING_ENABLED=true
THREADS_AUTO_POSTS_PER_DAY=3
THREADS_AUTO_POST_HOURS=10,14,18
THREADS_AUTO_POST_TIMEZONE=Asia/Almaty
THREADS_AUTO_GENERATE_IF_QUEUE_EMPTY=true
THREADS_DAILY_POST_LIMIT=3
THREADS_GROWTH_MODE_ENABLED=true
THREADS_MIN_QUEUE_SIZE=7
THREADS_VIRAL_ONLY=true

GROWTH_AUTOPILOT_ENABLED=true
GROWTH_DAILY_REPORT_ENABLED=true
GROWTH_REPORT_HOUR=21
GROWTH_REPORT_TIMEZONE=Asia/Almaty

COMMENT_DISCOVERY_ENABLED=true
COMMENT_AUTO_REPLY_ENABLED=false
COMMENT_APPROVAL_REQUIRED=true
COMMENT_DAILY_LIMIT=3
COMMENT_SEARCH_TOPICS=заявки,продажи,Direct,CRM,администратор,WhatsApp,Telegram,AI-бот
COMMENT_MIN_RELEVANCE_SCORE=70
COMMENT_REPORT_HOUR=20
COMMENT_REPORT_TIMEZONE=Asia/Almaty

# Safe Lead Hunter Agent (queue-first/manual-send, no scraping or mass DM)
LEAD_HUNTER_ENABLED=true
LEAD_HUNTER_AUTOPILOT_ENABLED=false
LEAD_HUNTER_AUTO_DM_ENABLED=false
LEAD_HUNTER_APPROVAL_REQUIRED=true
LEAD_HUNTER_DAILY_DM_LIMIT=3
LEAD_HUNTER_MIN_SCORE=80
LEAD_HUNTER_ALLOWED_CHANNELS=telegram
LEAD_HUNTER_REQUIRE_PERSONALIZATION=true
LEAD_HUNTER_BLOCK_IF_NO_OFFICIAL_CHANNEL=true
LEAD_HUNTER_REPORT_HOUR=21
LEAD_HUNTER_TIMEZONE=Asia/Almaty

# Autonomous Threads Growth Agent (safe by default)
AUTONOMOUS_THREADS_AGENT_ENABLED=false
AUTONOMOUS_THREADS_AGENT_AUTO_START=false
AUTONOMOUS_THREADS_AGENT_DRY_RUN=true
AUTONOMOUS_THREADS_AGENT_TIMEZONE=Asia/Almaty
AUTONOMOUS_THREADS_DAILY_POST_TARGET=3
AUTONOMOUS_THREADS_DAILY_COMMENT_LIMIT=5
AUTONOMOUS_THREADS_DAILY_DM_LIMIT=2
AUTONOMOUS_THREADS_DAILY_SCAN_LIMIT=30
AUTONOMOUS_THREADS_MIN_COMMENT_SCORE=80
AUTONOMOUS_THREADS_MIN_DM_SCORE=85
AUTONOMOUS_THREADS_START_HOUR=10
AUTONOMOUS_THREADS_END_HOUR=20
AUTONOMOUS_THREADS_MIN_DELAY_MINUTES=45
AUTONOMOUS_THREADS_MAX_DELAY_MINUTES=120
AUTONOMOUS_THREADS_COMMENTS_ENABLED=false
AUTONOMOUS_THREADS_DMS_ENABLED=false
AUTONOMOUS_THREADS_BROWSER_MODE=false
AUTONOMOUS_THREADS_STOP_ON_CAPTCHA=true
AUTONOMOUS_THREADS_STOP_ON_CHECKPOINT=true
AUTONOMOUS_THREADS_STOP_ON_RATE_LIMIT=true
AUTONOMOUS_THREADS_STOP_ON_ACTION_BLOCKED=true
AUTONOMOUS_THREADS_STOP_ON_LOGIN_ISSUE=true
AUTONOMOUS_THREADS_NO_MASS_DM=true
AUTONOMOUS_THREADS_NO_DUPLICATES=true
AUTONOMOUS_THREADS_NO_LINKS_IN_FIRST_TOUCH=true
AUTONOMOUS_THREADS_NO_PRICE_IN_FIRST_TOUCH=true
